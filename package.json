{
  "name": "secret-file-cautioner",
  "publisher": "tagucch",
  "displayName": "Secret File Cautioner",
  "description": "Warns before opening files that may contain sensitive values (e.g. .env files)",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "secretFileCautioner.warningEditor",
        "displayName": "Secret File Cautioner",
        "selector": [
          {
            "filenamePattern": ".env"
          },
          {
            "filenamePattern": ".env.*"
          },
          {
            "filenamePattern": "*.pem"
          },
          {
            "filenamePattern": "*.key"
          },
          {
            "filenamePattern": "*.p12"
          },
          {
            "filenamePattern": "*.pfx"
          },
          {
            "filenamePattern": "id_rsa"
          },
          {
            "filenamePattern": "id_ed25519"
          },
          {
            "filenamePattern": "id_ecdsa"
          },
          {
            "filenamePattern": "id_dsa"
          },
          {
            "filenamePattern": "credentials.json"
          },
          {
            "filenamePattern": ".npmrc"
          },
          {
            "filenamePattern": ".netrc"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Secret File Cautioner",
      "properties": {
        "secretFileCautioner.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the secret file warning."
        },
        "secretFileCautioner.filePatterns": {
          "type": "array",
          "default": [
            ".env"
          ],
          "items": {
            "type": "string"
          },
          "description": "File patterns that trigger the warning for the dynamic watcher. Supports partial match (e.g. '.env') and regex (e.g. '/^\\.env.*/')."
        },
        "secretFileCautioner.warningMessage": {
          "type": "string",
          "default": "このファイルには公開すると危険な値が書かれている可能性があります。開きますか？",
          "description": "The warning message displayed when opening a sensitive file."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "check-types": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "package": "node esbuild.js --production",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "pretest:integration": "tsc -p test/tsconfig.json && npm run compile",
    "test:integration": "vscode-test",
    "test": "npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.20.0",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  }
}
